                {
                    "name": "Register",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "// Test 1: cek status code harus 201\r\npm.test(\"Status code sesuai\", function () {\r\n    pm.response.to.have.status(201);\r\n});\r\n\r\n// Test 2: cek response punya success: true\r\npm.test(\"Response success true\", function () {\r\n    var jsonData = pm.response.json();\r\n    pm.expect(jsonData.success).to.eql(true);\r\n});\r\n\r\n// Script otomatis simpan token ke environment variable\r\n// pm.response.json() = ambil response body sebagai object JavaScript\r\n// jsonData.data.token = ambil nilai token dari response\r\n// pm.environment.set = simpan ke variabel environment yang aktif (Local)\r\nif (pm.response.code === 201) {\r\n    var jsonData = pm.response.json();\r\n    pm.environment.set(\"token\", jsonData.data.token);\r\n    console.log(\"Token berhasil disimpan:\", jsonData.data.token);\r\n}"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "appliation/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\r\n    \"name\": \"Seller Satu\",\r\n    \"email\": \"seller@example.com\",\r\n    \"password\": \"password123\",\r\n    \"password_confirmation\": \"password123\",\r\n    \"role\": \"seller\"\r\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{base_url}}/register",
                            "host": ["{{base_url}}"],
                            "path": ["register"]
                        }
                    },
                    "response": []
                },
